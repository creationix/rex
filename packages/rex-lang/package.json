{
	"name": "@creationix/rex",
	"version": "0.1.4",
	"description": "Compiler and parser for the Rex language",
	"keywords": [
		"rex",
		"dsl",
		"compiler",
		"parser",
		"configuration"
	],
	"type": "module",
	"bin": {
		"rex": "./rex-cli.js"
	},
	"main": "rex.js",
	"types": "./rex.ts",
	"exports": {
		".": "./rex.js"
	},
	"files": [
		"README.md",
		"LICENSE",
		"rex.js",
		"rex-compile.js",
		"rex.ts",
		"rex-compile.ts",
		"rex-cli.js",
		"rex.ohm",
		"rex.ohm-bundle.cjs",
		"rex.ohm-bundle.js",
		"rex.ohm-bundle.d.ts",
		"rexc-interpreter.ts"
	],
	"scripts": {
		"test": "bun test",
		"build:grammar": "ohm generateBundles --withTypes rex.ohm && node -e \"require('node:fs').copyFileSync('rex.ohm-bundle.js','rex.ohm-bundle.cjs')\"",
		"build:js": "bun build rex.ts --outfile rex.js --format esm --target node && bun build rex-compile.ts --outfile rex-compile.js --format esm --target node",
		"compile": "bun run rex-compile.ts",
		"verify:docs": "bun run verify-doc-examples.ts",
		"pack:dry-run": "npm pack --dry-run",
		"prepublishOnly": "bun run build:grammar && bun test && bun run build:js && npm run pack:dry-run"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/creationix/rex",
		"directory": "packages/rex-lang"
	},
	"license": "MIT",
	"dependencies": {
		"ohm-js": "^17.1.0"
	},
	"devDependencies": {
		"@ohm-js/cli": "^2.0.1",
		"@types/bun": "latest"
	}
}
