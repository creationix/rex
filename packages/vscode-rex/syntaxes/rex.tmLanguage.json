{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Rex Language",
	"scopeName": "source.rex",
	"wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
	"patterns": [{ "include": "#expressions" }],
	"repository": {
		"expressions": {
			"patterns": [
				{ "include": "#comment" },
				{ "include": "#string-single" },
				{ "include": "#string-double" },
				{ "include": "#number" },
				{ "include": "#literal-keyword" },
				{ "include": "#control-keyword" },
				{ "include": "#self-depth" },
				{ "include": "#existence-operator" },
				{ "include": "#comparison-operator" },
				{ "include": "#assignment-operator" },
				{ "include": "#value-operator" },
				{ "include": "#comma-separator" },
				{ "include": "#container-paren" },
				{ "include": "#container-bracket" },
				{ "include": "#container-brace" },
				{ "include": "#object-key" },
				{ "include": "#navigation-dynamic" },
				{ "include": "#navigation-static" },
				{ "include": "#function-call" },
				{ "include": "#identifier" }
			]
		},
		"comment": {
			"patterns": [
				{ "include": "#comment-line" },
				{ "include": "#comment-block" }
			]
		},
		"comment-line": {
			"match": "//.*$",
			"name": "comment.line.double-slash.rex"
		},
		"comment-block": {
			"begin": "/\\*",
			"end": "\\*/",
			"name": "comment.block.rex"
		},
		"string-single": {
			"begin": "'",
			"end": "'",
			"name": "string.quoted.single.rex",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.rex" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.rex" }
			},
			"patterns": [
				{
					"match": "\\\\u[0-9a-fA-F]{4}",
					"name": "constant.character.escape.unicode.rex"
				},
				{
					"match": "\\\\x[0-9a-fA-F]{2}",
					"name": "constant.character.escape.hex.rex"
				},
				{
					"match": "\\\\['\"\\\\\\/bfnrt0]",
					"name": "constant.character.escape.rex"
				},
				{
					"match": "\\\\.",
					"name": "invalid.illegal.escape.rex"
				}
			]
		},
		"string-double": {
			"begin": "\"",
			"end": "\"",
			"name": "string.quoted.double.rex",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.rex" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.rex" }
			},
			"patterns": [
				{
					"match": "\\\\u[0-9a-fA-F]{4}",
					"name": "constant.character.escape.unicode.rex"
				},
				{
					"match": "\\\\x[0-9a-fA-F]{2}",
					"name": "constant.character.escape.hex.rex"
				},
				{
					"match": "\\\\['\"\\\\\\/bfnrt0]",
					"name": "constant.character.escape.rex"
				},
				{
					"match": "\\\\.",
					"name": "invalid.illegal.escape.rex"
				}
			]
		},
		"number": {
			"patterns": [
				{
					"match": "(?<![a-zA-Z_])-?\\b0[xX][0-9a-fA-F]+\\b",
					"name": "constant.numeric.hex.rex"
				},
				{
					"match": "(?<![a-zA-Z_])-?\\b0[bB][01]+\\b",
					"name": "constant.numeric.binary.rex"
				},
				{
					"match": "(?<![a-zA-Z_])-?\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b",
					"name": "constant.numeric.rex"
				}
			]
		},
		"literal-keyword": {
			"match": "\\b(true|false|null|undefined|nan)\\b|-?\\binf\\b",
			"name": "constant.language.rex"
		},
		"control-keyword": {
			"match": "\\b(when|unless|else|while|for|in|of|do|end|break|continue)\\b",
			"name": "keyword.control.rex"
		},
		"self-depth": {
			"match": "\\bself(?:@[1-9][0-9]*)?\\b",
			"name": "variable.language.self.rex"
		},
		"existence-operator": {
			"match": "\\b(and|or)\\b",
			"name": "keyword.operator.logical.rex"
		},
		"comparison-operator": {
			"match": "==|!=|<=|>=|<|>",
			"name": "keyword.operator.comparison.rex"
		},
		"assignment-operator": {
			"match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|=",
			"name": "keyword.operator.assignment.rex"
		},
		"value-operator": {
			"match": "[+\\-*/%^&|~]",
			"name": "keyword.operator.rex"
		},
		"comma-separator": {
			"match": ",",
			"name": "punctuation.separator.comma.rex"
		},
		"container-paren": {
			"begin": "\\(",
			"end": "\\)",
			"beginCaptures": {
				"0": { "name": "punctuation.section.parens.begin.rex" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.parens.end.rex" }
			},
			"patterns": [{ "include": "#expressions" }]
		},
		"container-bracket": {
			"begin": "\\[",
			"end": "\\]",
			"beginCaptures": {
				"0": { "name": "punctuation.section.brackets.begin.rex" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.brackets.end.rex" }
			},
			"patterns": [{ "include": "#expressions" }]
		},
		"container-brace": {
			"begin": "\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "punctuation.section.braces.begin.rex" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.braces.end.rex" }
			},
			"patterns": [{ "include": "#expressions" }]
		},
		"object-key": {
			"match": "((?:[a-zA-Z_][a-zA-Z0-9_-]*|-?[0-9]+)|'(?:\\\\.|[^'\\\\])*'|\"(?:\\\\.|[^\"\\\\])*\")\\s*(:)",
			"captures": {
				"1": { "name": "support.type.property-name.rex" },
				"2": { "name": "punctuation.separator.key-value.rex" }
			}
		},
		"navigation-dynamic": {
			"match": "\\.\\(",
			"name": "meta.navigation.dynamic.rex"
		},
		"navigation-static": {
			"match": "\\.[a-zA-Z_][a-zA-Z0-9_-]*",
			"name": "meta.navigation.static.rex"
		},
		"function-call": {
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\s*(?=\\()",
			"name": "entity.name.function.rex"
		},
		"identifier": {
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b",
			"name": "variable.other.rex"
		}
	}
}
