{
  "globals": {
    "env": {
      "ref": 5,
      "type": "string",
      "description": "Deployment environment name from host runtime"
    },
    "req": {
      "ref": 6,
      "type": "object",
      "description": "Inbound request surface provided by host runtime",
      "properties": {
        "headers": {
          "type": "header-map<multi-value>",
          "aliases": ["headers"],
          "description": "Request headers exposed as a case-insensitive multi-value map",
          "properties": {
            "x-action": { "type": "string", "description": "Action identifier for router lookup" },
            "x-tenant": { "type": "string", "description": "Tenant identifier" },
            "x-request-id": { "type": "string", "description": "Request correlation id" }
          }
        },
        "method": {
          "type": "string",
          "aliases": ["method"],
          "description": "Request method (GET, POST, ... )"
        },
        "domain": {
          "type": "domain<string + segments>",
          "aliases": ["domain"],
          "description": "Host/domain name value that behaves like both full string and array of segments"
        },
        "path": {
          "type": "path<string + segments>",
          "aliases": ["path"],
          "description": "URL path value that behaves like both full string and array of segments"
        },
        "querystring": {
          "type": "querystring<string + multi-value-map>",
          "aliases": ["querystring"],
          "description": "Raw querystring that also exposes parsed multi-value parameters"
        },
        "query": {
          "type": "query-map<multi-value>",
          "aliases": ["query"],
          "description": "Parsed query parameters as multi-value map"
        },
        "cookies": {
          "type": "object",
          "aliases": ["cookies"],
          "description": "Inbound cookie map"
        },
        "body": {
          "type": "string",
          "aliases": ["body"],
          "description": "Inbound raw request body"
        },
        "ip": {
          "type": "string",
          "aliases": ["ip"],
          "description": "Client IP address"
        }
      }
    },
    "res": {
      "ref": 7,
      "type": "object",
      "description": "Mutable response state",
      "properties": {
        "headers": {
          "type": "header-map<multi-value>",
          "aliases": ["response-headers"],
          "description": "Response headers as a writable multi-value map"
        },
        "status": {
          "type": "number",
          "aliases": ["status"],
          "description": "Response status code"
        }
      }
    },
    "auth": {
      "ref": 8,
      "type": "object",
      "description": "Authentication context",
      "properties": {
        "user-id": { "type": "string", "description": "Authenticated user id" },
        "roles": { "type": "array", "description": "User role list" }
      }
    },
    "edge-config": {
      "ref": 9,
      "type": "object",
      "description": "Host-managed read-only project edge configuration attached by customers",
      "properties": {
        "routing": {
          "type": "object",
          "description": "Routing-level runtime config",
          "properties": {
            "default-operation-timeout-ms": { "type": "number", "description": "Default operation timeout when routes omit explicit timeout" },
            "response-tag": { "type": "string", "description": "Optional response tag stamped into headers" }
          }
        }
      }
    },
    "trace": {
      "ref": 10,
      "type": "function",
      "description": "Platform trace emitter"
    },
    "trace-id": {
      "ref": 11,
      "type": "function",
      "description": "Generates a request correlation id"
    },
    "trade-id": {
      "ref": 12,
      "type": "function",
      "description": "Alias for trace-id in some samples/tooling"
    },
    "provider-signing-secret": {
      "ref": 13,
      "type": "function",
      "description": "Host-managed read-only secret lookup for webhook providers"
    },
    "cors-allow-origin": {
      "ref": 14,
      "type": "function",
      "description": "Computes CORS allow-origin header from request origin"
    },
    "tenant-config": {
      "ref": 15,
      "type": "function",
      "description": "Loads tenant policy/config by tenant id"
    },
    "api-key-valid": {
      "ref": 16,
      "type": "function",
      "description": "Validates API key for a tenant"
    },
    "session-valid": {
      "ref": 17,
      "type": "function",
      "description": "Validates session token for a tenant"
    },
    "session-has-role": {
      "ref": 18,
      "type": "function",
      "description": "Checks if session token has a required role"
    },
    "verify-signature": {
      "ref": 19,
      "type": "function",
      "description": "Verifies webhook/request signature"
    },
    "rate-limit-allow": {
      "ref": 20,
      "type": "function",
      "description": "Checks and records rate-limit allowance"
    },
    "json-parse": {
      "ref": 21,
      "type": "function",
      "description": "Parses JSON text into an object"
    },
    "schema-for-operation": {
      "ref": 22,
      "type": "function",
      "description": "Returns validation schema for an operation"
    },
    "validate-json": {
      "ref": 23,
      "type": "function",
      "description": "Validates object against schema"
    },
    "validation-errors": {
      "ref": 24,
      "type": "function",
      "description": "Returns validation error details from last validation"
    },
    "idempotency-read": {
      "ref": 25,
      "type": "function",
      "description": "Fetches prior idempotent write result"
    },
    "query-cache-key": {
      "ref": 26,
      "type": "function",
      "description": "Normalizes query object into cache key fragment"
    },
    "cache-read": {
      "ref": 27,
      "type": "function",
      "description": "Reads cached response by cache key"
    },
    "cache-write": {
      "ref": 28,
      "type": "function",
      "description": "Writes response to cache with TTL"
    },
    "execute-operation": {
      "ref": 29,
      "type": "function",
      "description": "Executes upstream/domain operation"
    },
    "merge-headers": {
      "ref": 30,
      "type": "function",
      "description": "Merges response header objects"
    },
    "audit-write": {
      "ref": 31,
      "type": "function",
      "description": "Writes audit event record"
    },
    "number": {
      "ref": 32,
      "type": "function",
      "description": "Converts value to number"
    }
  }
}
